{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Studio S",
  "version": "0.3.56",
  "identifier": "com.supergood.studios",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Studio S",
        "width": 1280,
        "height": 840,
        "resizable": true,
        "decorations": true,
        "backgroundColor": "#000000"
      }
    ],
    "security": {
      "csp": null
    }
